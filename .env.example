# Mupin — unified root environment configuration
#
# This is the global default .env for the whole Mupin system.
# Each module (mupin-api-backbone, mupin-coding-module, mupin-editing-module)
# can have its own .env file that overrides these values for module-specific use.
# When running via docker-compose, the root .env is loaded first and module .env
# files override shared keys.

# =============================================================================
# Shared infrastructure
# =============================================================================

# Postgres connection (used by mupin-api-backbone)
DATABASE_URL=postgresql+asyncpg://mupin:mupin@postgres:5432/mupin

# Redis connection for ARQ queue
REDIS_URL=redis://redis:6379/0

# Backbone URL as seen from other services
BACKBONE_URL=http://mupin-api-backbone:8000

# API ports exposed on the host
BACKBONE_PORT=8001
CODING_API_PORT=8000
EDITING_API_PORT=8003
PLANNER_PORT=8004

# Optional: log level
LOG_LEVEL=info

# Host user identity for sandbox containers. Defaults to 1000:1000.
PUID=1000
PGID=1000

# =============================================================================
# LLM providers
# =============================================================================

# Ollama Cloud API key (required for provider: "ollama-cloud").
OLLAMA_API_KEY=sk-your-ollama-cloud-key

# Optional: Google GenAI key, only needed if a node is pointed at google-genai.
GOOGLE_API_KEY=

# Optional: OpenAI key, only needed if a node is pointed at openai.
# OPENAI_API_KEY=

# Optional: Anthropic key, only needed if a node is pointed at anthropic.
# ANTHROPIC_API_KEY=

# Optional: override the local Ollama daemon location (provider: "ollama").
# OLLAMA_BASE_URL=http://localhost:11434
