# Python
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/
env/

# Environment variables (API keys — NEVER commit)
.env
.env.local

# LangGraph / Swarm output directories
.workspaces/
coding-module/.workspaces/
mupin-coding-module/.workspaces/
# Optional persistent shared dependency cache (large)
.deps_cache/
coding-module/.deps_cache/
mupin-coding-module/.deps_cache/
# Generated per-task snapshots (can be large)
.workspace-snapshot/
mupin-coding-module/.workspace-snapshot/

# Benchmark run output (append-only history; runner.py + questions.json ARE tracked)
coding-module/benchmarks/results.jsonl
coding-module/benchmarks/results-*.jsonl
coding-module/benchmarks/metrics.jsonl
coding-module/benchmarks/metrics-*.jsonl
coding-module/benchmarks/*.out
coding-module/benchmarks/logs/*.out
coding-module/benchmarks/logs/*.log
coding-module/benchmarks/run_*.log
mupin-coding-module/benchmarks/results.jsonl
mupin-coding-module/benchmarks/results-*.jsonl
mupin-coding-module/benchmarks/metrics.jsonl
mupin-coding-module/benchmarks/metrics-*.jsonl
mupin-coding-module/benchmarks/*.out
mupin-coding-module/benchmarks/logs/*.out
mupin-coding-module/benchmarks/logs/*.log
mupin-coding-module/benchmarks/run_*.log
mupin-coding-module/benchmarks/humaneval_results.jsonl
mupin-coding-module/benchmarks/humaneval_rescore*.jsonl
mupin-coding-module/benchmarks/bigcodebench_results*.jsonl
mupin-coding-module/benchmarks/tmux_*.log
mupin-coding-module/benchmarks/tmux_*.sh

# Ollama data & models
ollama_data/

# Testing and coverage
.pytest_cache/
.hypothesis/
.coverage
htmlcov/

# Docker
docker-compose.override.yml

# IDE / tool config
.claude/settings.local.json

# aider working files (chat history, input history, repo-map cache)
.aider*

# Handover / internal notes (loaded into aider via .aender.conf.yml, not for the public repo)
HANDOVER.md

# OS generated files
.DS_Store
Thumbs.db
