# Copy to .env and fill in the keys for whichever providers llm_config.yaml uses.
# The default config routes every node directly to Ollama Cloud.

# Ollama Cloud API key (required for provider: "ollama-cloud").
OLLAMA_API_KEY=sk-your-ollama-cloud-key

# Optional: only needed if you point a node at one of these premium providers.
GOOGLE_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional: override the local Ollama daemon location (provider: "ollama").
# OLLAMA_BASE_URL=http://localhost:11434

# Optional: host user identity for sandbox containers. Defaults to 1000:1000.
# PUID=1000
# PGID=1000
