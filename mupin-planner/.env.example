# Mupin Planner — environment configuration
# Copies values from root .env; module-local overrides only if needed.

# Ollama Cloud API key (required for planner LLM calls).
OLLAMA_API_KEY=sk-your-ollama-cloud-key

# Optional: other providers if llm_config.yaml points at them.
GOOGLE_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Backbone URL as seen from this container.
BACKBONE_URL=http://mupin-api-backbone:8000